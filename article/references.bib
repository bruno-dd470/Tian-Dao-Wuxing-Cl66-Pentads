  abstract = {The ALPHA-g experiment at CERN measures the gravitational acceleration of antihydrogen atoms. The results show that antihydrogen falls downward under gravity, consistent with the behaviour of matter, ruling out repulsive gravity at the level of 1g. The best-fit value of the effective gravitational acceleration is g_Hbar = (0.75 ± 0.13 (stat. + syst.) ± 0.16 (simulation)) × g.}
}
